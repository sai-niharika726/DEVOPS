<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Capture | Print Store</title>
    <style>
        :root {
            --bg: #fafafa;
            --text: #1a1a1a;
            --accent: #666;
        }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background: var(--bg);
            color: var(--text);
            margin: 0;
            padding: 0;
        }
        header {
            padding: 4rem 2rem;
            text-align: center;
            text-transform: uppercase;
            letter-spacing: 0.2rem;
        }
        .container {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 2rem;
            padding: 0 2rem 4rem;
        }
        .card {
            overflow: hidden;
            transition: transform 0.3s ease;
        }
        .card:hover {
            transform: translateY(-5px);
        }
        .card img {
            width: 100%;
            height: 350px;
            object-fit: cover;
            background: #eee;
        }
        .card-info {
            padding: 1rem 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .card-title {
            font-weight: 500;
            margin: 0;
        }
        .card-price {
            color: var(--accent);
            font-size: 0.9rem;
        }
        button {
            background: var(--text);
            color: white;
            border: none;
            padding: 0.5rem 1rem;
            cursor: pointer;
            margin-top: 0.5rem;
            width: 100%;
            transition: opacity 0.2s;
        }
        button:hover {
            opacity: 0.8;
        }
    </style>
</head>
<body>
    <header>
        <h1>Capture Store</h1>
        <p>Fine Art Photography Prints</p>
    </header>

    <main class="container">
        <% gallery.forEach(item => { %>
            <div class="card">
                <img src="<%= item.img %>" alt="<%= item.title %>">
                <div class="card-info">
                    <h3 class="card-title"><%= item.title %></h3>
                    <span class="card-price">$<%= item.price %></span>
                </div>
                <button>Add to Cart</button>
            </div>
        <% }) %>
    </main>
</body>
</html>
